{
  "expo": {
    "name": "cargex-driver-app",
    "slug": "cargex-driver-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cargex.driver"
    },
    "android": {
      "package": "com.cargex.driver",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
